# 忽略虚拟环境
.venv/
venv/
ENV/

# 忽略 Python 缓存
__pycache__/
*.py[cod]

# 忽略环境变量 (保护你的 API Keys)
.env

# 忽略系统文件
.DS_Store

# 忽略前端依赖和构建产物
node_modules/
frontend/node_modules/
frontend/dist/

# 忽略 storage 下的运行时缓存
storage/__pycache__/

# 离线 embedding / rerank 评测输出（不提交到仓库）
embedding_eval_out/
embedding_eval_runs/
embedding_eval_runs_size_compare/
rerank_eval_runs*/

# 离线评测 sandbox（脚本、金标、本地样例等；需要进仓库时再单独放开）
data_sandbox/
