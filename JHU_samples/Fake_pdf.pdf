   "source": [
    "for i in range(len(res)): # 确定循环范围\n",
    "# 查询每个出发地出发延误的平均值、最小值、最大值\n",
    "    sql2 = \"select avg(DepTime-CRSDepTime), min(DepTime-CRSDepTime),max(DepTime-CRSDepTime) from flight_time where Id in (select Id from flight_info where Origin = '\" + ''.join(res[i]) + \"' and Cancelled=0)\"\n",
    "    cur.execute(sql2)\n",
    "    res2 = cur.fetchall()\n",
    "    new = pd.DataFrame(res2) # 将运行结果转换为数据框\n",
    "    new['Origin'] = res[i] # 新建列，存入出发地\n",
    "# 重命名各列\n",
    "    new.columns = ['Avg_DepDelay', 'Min_DepDelay', 'Max_DepDelay', 'Origin'] # 对列进行重新排序\n",
    "    colorder = ['Origin', 'Avg_DepDelay', 'Min_DepDelay', 'Max_DepDelay']\n",
    "    new = new[colorder]\n",
    "# 将该次查询结果存入数据框 output 中\n",
    "    output = output.append(new, ignore_index=True)\n",
    "\n",
    "outputdesc = output.sort_values(by='Avg_DepDelay', ascending = False)\n",
    "# 输出数据框前 10 行\n",
    "print(outputdesc.head(10))"
   ]
