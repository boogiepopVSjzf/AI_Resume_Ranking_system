DATABASE_URL=postgresql://db_user:db_password@your-rds-endpoint.amazonaws.com:5432/postgres
DATABASE_SSLMODE=require
ENABLE_DB_PERSISTENCE=true
DB_AUTO_INIT=true
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=resume-pdf
ENABLE_S3_STORAGE=true

LLM_API_KEY=
DEFAULT_LLM_PROVIDER=dashscope
DEFAULT_LLM_MODEL=qwen-max

# Role-specific LLM routing.
# Leave *_LLM_MODEL empty to use the provider's default model from config/settings.py.
# Supported providers: dashscope, openai, anthropic, gemini, ollama.
PARSE_QUERY_LLM_PROVIDER=dashscope
PARSE_QUERY_LLM_MODEL=
SCHEMA_LLM_PROVIDER=dashscope
SCHEMA_LLM_MODEL=
SCORING_LLM_PROVIDER=dashscope
SCORING_LLM_MODEL=

# Optional provider keys if you route a role to another provider.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OLLAMA_MODEL=deepseek-r1:1.5b

EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DEVICE=cpu
EMBEDDING_DIMENSION=384
ENABLE_RERANKER=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_DEVICE=cpu
PRELOAD_RERANKER_MODEL=false
RERANKER_CANDIDATE_POOL_SIZE=20
